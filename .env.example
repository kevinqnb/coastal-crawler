# ------------------------------------------------------------------ core
DATABASE_URL=postgresql://user:pass@localhost:5432/coastal_crawler
BATCH_SIZE=10

# ------------------------------------------------------------ sources
# Comma-separated list; add "semantic_scholar" and/or "wiley" to enable them.
ENABLED_SOURCES=openalex

# ---------------------------------------------------------- OpenAlex
OPENALEX_API_KEY=                   # optional — register at https://openalex.org/register for higher rate limits
# Comma-separated OpenAlex topic IDs (T-prefixed). Browse topics at https://api.openalex.org/topics
OPENALEX_TOPIC_IDS=T10032,T10779,T13485,T10643

# ------------------------------------------------- Semantic Scholar
# API key is optional but raises the rate limit from 1 to 100 req/s.
SEMANTIC_SCHOLAR_API_KEY=
# Comma-separated keyword queries
SEMANTIC_SCHOLAR_QUERIES='(coastal | estuary | estuarine | "salt marsh" | mangrove | seagrass | "tidal flat" | nearshore | lagoon | "continental shelf") + (measurement | observation | flux | "time series" | monitoring | "in situ" | sensor | profile | sampling) + (salinity | temperature | turbidity | "dissolved oxygen" | nutrient | nitrogen | phosphorus | chlorophyll | "primary production" | alkalinity | pH | pCO2 | "carbon flux" | sediment | hydrodynamic)'

# ------------------------------------------------------- Wiley TDM
# Required if "wiley" is in ENABLED_SOURCES.
WILEY_API_KEY=
# Optional subject codes and/or journal ISSNs to narrow the query.
WILEY_SUBJECTS=
WILEY_ISSNS=19395590,23782242

# -------------------------------------------------- Abstract filter
# Run `coastal-crawler filter` between discovery and extraction.
#
# FILTER_BASE_URL: OpenAI-compatible endpoint. Set to your vLLM server for
#   local models, or leave blank to use the OpenAI cloud API.
FILTER_BASE_URL=http://localhost:8082/v1

# FILTER_API_KEY: Use "EMPTY" for local vLLM (no auth). Replace with your
#   real key for OpenAI or other hosted providers.
FILTER_API_KEY=EMPTY

# FILTER_MODEL: The model to query. For vLLM this is the --served-model-name
#   value (or the HuggingFace path if you didn't set one).
FILTER_MODEL=Qwen/Qwen3-0.6B

# FILTER_RELEVANCE_PROMPT: System-role instruction that defines relevance
#   criteria. The pipeline appends its own output-format instruction, so you
#   only need to describe the science. The model responds with a single token
#   (true or false); confidence is derived from the logprob ratio.
#
#   The prompt below is tuned for coastal-ecosystem field-measurement papers.
#   Edit it to match your target domain or add/remove exclusion rules.
FILTER_RELEVANCE_PROMPT="You are screening papers for a coastal and marine biogeochemistry database. A paper is relevant if it reports field measurements, in situ observations, or monitoring data from any of the following environments: estuaries, salt marshes, tidal flats (mud flats, sand flats), mangroves, lagoons, tidal creeks, coastal wetlands, seagrass beds, kelp forests, coral or shellfish reefs, rocky shores, intertidal and subtidal zones, continental shelves, shelf seas, upwelling zones, frontal zones, oxygen minimum zones, or deep-sea features such as hydrothermal vents, cold seeps, and seamounts.\n\nTo qualify, the paper must report at least one of the following variables: salinity, turbidity, suspended particulate matter, light attenuation, dissolved oxygen, sediment oxygen demand, pCO2, dissolved inorganic carbon, total alkalinity, CO2 flux, dissolved or particulate organic carbon, primary production (net or gross), chlorophyll, nitrate, ammonium, total nitrogen, denitrification, nitrification, nitrogen fixation, phosphate, or silicate.\n\nReject a paper if it is a pure review or meta-analysis with no new field data, a modeling or simulation study without supporting observations, or a purely laboratory study with no field site component."

# -- Inference parameters (passed to every API call) --------------------------
# Set these to the same values used when launching the server so that
# runs are fully reproducible.
FILTER_BATCH_SIZE=50
FILTER_SEED=342
FILTER_TEMPERATURE=0.0
FILTER_TOP_LOGPROBS=20

# -- Serving parameters (used only by scripts/serve_model.sh FILTER) ----------
# FILTER_PORT must match the port in FILTER_BASE_URL above.
FILTER_PORT=8082
FILTER_TENSOR_PARALLEL_SIZE=1        # number of GPUs for tensor parallelism
FILTER_GPU_MEMORY_UTILIZATION=0.90   # fraction of GPU memory vLLM may use
FILTER_DTYPE=auto                    # auto | bfloat16 | float16 | float32
FILTER_QUANTIZATION=                 # awq | gptq | fp8 | (blank = none)
FILTER_MAX_MODEL_LEN=                # override context length (blank = model default)

# -- Singularity container (optional — for HPC clusters) ----------------------
# If set, scripts/serve_model.sh runs vLLM inside this .sif image instead
# of calling vllm directly. Leave blank for local workstation use.
#
# Build the SIF once, pinning a specific tag:
#   singularity pull vllm-openai.sif docker://vllm/vllm-openai:<tag>
#
# HuggingFace cache is read from HF_HOME (or ~/.cache/huggingface by default)
# — set that in your shell profile or job script, not here.
FILTER_SIF_PATH=/path/to/vllm-openai.sif

# ------------------------------------------------ Document LM (OCR/VLM)
# Run `coastal-crawler extract` after filtering. DocumentLM (OCR) and
# MeasurementLM (extraction, below) are each served by their own vLLM
# instance — see scripts/serve_model.sh and scripts/submit_extract_job.sh,
# which colocate both servers on one multi-GPU node pinned to distinct GPUs.
#
# DOC_LM_BASE_URL: OpenAI-compatible endpoint for the OCR/VLM model.
DOC_LM_BASE_URL=http://localhost:8083/v1
DOC_LM_API_KEY=EMPTY

# DOC_LM_MODEL: the OCR/VLM model to serve, e.g. allenai/olmOCR-2-7B-1025.
DOC_LM_MODEL=

# -- Serving parameters (used only by scripts/serve_model.sh DOC_LM) ----------
DOC_LM_PORT=8083
DOC_LM_TENSOR_PARALLEL_SIZE=1
DOC_LM_GPU_MEMORY_UTILIZATION=0.90
DOC_LM_DTYPE=auto
DOC_LM_SEED=0
DOC_LM_QUANTIZATION=
DOC_LM_MAX_MODEL_LEN=

# Maximum concurrent OCR page-image API calls the client sends at once.
# Client-side concurrency, not a vLLM server flag. Default: 32.
DOC_LM_MAX_CONCURRENT=32

# -- Singularity container (optional — for HPC clusters) ----------------------
DOC_LM_SIF_PATH=

# --------------------------------------- Measurement LM (extraction)
# MEAS_LM_BASE_URL: OpenAI-compatible endpoint for the extraction LLM.
MEAS_LM_BASE_URL=http://localhost:8084/v1
MEAS_LM_API_KEY=EMPTY

# MEAS_LM_MODEL: the extraction LLM to serve.
MEAS_LM_MODEL=

# MEAS_LM_ENTITY_IDENTIFICATION_PROMPT: prompt describing what entities/
#   measurements to identify in each paper. The entity schema and attribute
#   catalogue (Python objects, not env vars) live in
#   src/coastal_crawler/measurement_schema.py — fill those in first.
MEAS_LM_ENTITY_IDENTIFICATION_PROMPT="You are an expert in identifying coastal and marine ecosystem sites referenced in scientific literature. Given the provided text (including any tables), extract all distinct coastal ecosystems or sampling sites.\n\nA coastal ecosystem/site is a specific, physically distinct location where field measurements, in situ observations, or monitoring data were collected. Multiple measurements of the same site (on different dates, under different conditions, at different sub-sites within it) should be represented as a single site record — those distinctions are captured separately as measurement events.\n\nWhat counts as a coastal ecosystem/site?: Include estuaries, salt marshes, tidal flats (mud flats, sand flats), mangroves, lagoons, tidal creeks, coastal wetlands, seagrass beds, kelp forests, coral or shellfish reefs, rocky shores, intertidal and subtidal zones, continental shelves, shelf seas, upwelling zones, frontal zones, oxygen minimum zones, and deep-sea features such as hydrothermal vents, cold seeps, and seamounts. If the ecosystem type is unclear, classify it as \"other\".\n\nFor each distinct site, identify: name (the site's name or primary identifier); identifiers (alternate short-form references — station codes, numeric tags, abbreviated names — used for the same site elsewhere in the text); ecosystem_type (e.g. estuary, salt marsh, tidal flat, mangrove, lagoon, tidal creek, coastal wetland, seagrass bed, kelp forest, coral reef, shellfish reef, rocky shore, intertidal zone, subtidal zone, continental shelf, shelf sea, upwelling zone, frontal zone, oxygen minimum zone, hydrothermal vent, cold seep, seamount, or other); location (the general geographic location, if stated); latitude and longitude (in decimal degrees, only if explicitly stated — never inferred from a place name).\n\nTreat sites with the same name as separate items only if clearly described as distinct physical locations. Do NOT split the same site into multiple entities because measurements were taken on different dates, sub-sites, or conditions — capture those distinctions as measurement events instead. Do NOT infer, guess, or derive any identifying information; use only what is explicitly stated in the text."

# -- Serving parameters (used only by scripts/serve_model.sh MEAS_LM) ---------
MEAS_LM_PORT=8084
MEAS_LM_TENSOR_PARALLEL_SIZE=1
MEAS_LM_GPU_MEMORY_UTILIZATION=0.90
MEAS_LM_DTYPE=auto
MEAS_LM_SEED=0
MEAS_LM_QUANTIZATION=
MEAS_LM_MAX_MODEL_LEN=

# -- Singularity container (optional — for HPC clusters) ----------------------
MEAS_LM_SIF_PATH=

# Maximum concurrent extraction API calls the client sends at once.
# Client-side concurrency, not a vLLM server flag. Was hardcoded to 1
# (fully serial) before this setting existed. Default: 4.
MEAS_LM_MAX_CONCURRENT=4

# ------------------------------------------------------- Extraction
# See src/coastal_crawler/measurement_schema.py to define EntitySchema and
# ATTRIBUTE_INFO_DICT for your domain before running `coastal-crawler extract`.
EXTRACTION_SCHEMA_NAME=coastal_measurement_v1
EXTRACTION_MODEL_VERSION=
# EntitySchema (measurement_schema.py) has latitude/longitude fields by default.
EXTRACTION_LAT_FIELD=latitude
EXTRACTION_LON_FIELD=longitude

# Papers processed per OCR+extraction GPU call within one claimed extract
# batch. Downloads for the next chunk run in a background thread while the
# current chunk's GPU work runs, hiding PDF download / Wiley-throttle wait
# time behind GPU compute. Default: 20.
EXTRACTION_CHUNK_SIZE=20